# Auto detect text files and perform LF normalization
* text=auto

# Source code files
*.cpp text eol=lf
*.c text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cuh text eol=lf
*.cu text eol=lf

# CMake files
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Configuration files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files
*.bin binary
*.so binary
*.dll binary
*.dylib binary
*.a binary
*.lib binary
*.exe binary
*.out binary
*.o binary
*.obj binary

# Model files
*.safetensors binary
*.gguf binary
*.ggml binary

# CUDA compiled files
*.cubin binary
*.fatbin binary
*.ptx binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary

# Git LFS tracking for large files
*.bin filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.gguf filter=lfs diff=lfs merge=lfs -text
*.ggml filter=lfs diff=lfs merge=lfs -text